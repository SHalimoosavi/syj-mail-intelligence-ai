# --- Environment ---
# "development": relaxed, API_KEY optional (with a loud warning if unset)
# "production": API_KEY is mandatory, the app refuses to start without it
ENVIRONMENT=development

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=
# Browser origins allowed to call this API directly (comma-separated). The
# dashboard doesn't need this — it proxies server-side. Only relevant if you
# call the API from some other browser-based client.
CORS_ALLOW_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=30

# --- Database (Phase 1: SQLite. Production: Postgres, see docker-compose.yml) ---
DATABASE_URL=sqlite:///./data/syj_mail.db
# Only used by docker-compose.yml (ignored by DATABASE_URL above when running
# SQLite directly outside Docker)
POSTGRES_PASSWORD=

# --- LLM provider (never OpenAI GPT) ---
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=qwen2.5:14b
LLM_FALLBACK_MODEL=qwen2.5:7b
LLM_TIMEOUT_SECONDS=60

# --- Approval thresholds (percent, 0-100) ---
AUTO_SEND_THRESHOLD=95
APPROVAL_THRESHOLD=80
IMPORTANCE_NOTIFY_THRESHOLD=70

# --- Gmail ---
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_POLL_INTERVAL_SECONDS=60
GMAIL_USER_EMAIL=me

# --- Telegram notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
